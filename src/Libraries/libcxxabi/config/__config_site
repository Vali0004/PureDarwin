//===----------------------------------------------------------------------===//
//
// PureDarwin: hand-resolved __config_site for the LLVM 21 libc++ tree.
//
// libc++'s __config_site is normally generated by CMake from
// libcxx/include/__config_site.in via #cmakedefine substitution. We build the
// libc++abi / libc++ subset out-of-tree (no libc++ CMake run), so we supply the
// resolved header directly. Values chosen to match Apple's macOS libc++ ABI:
// stable ABI v1, __1 inline namespace, pthread threading, full localization.
//
//===----------------------------------------------------------------------===//

#ifndef _LIBCPP___CONFIG_SITE
#define _LIBCPP___CONFIG_SITE

#define _LIBCPP_ABI_VERSION 1
#define _LIBCPP_ABI_NAMESPACE __1
/* _LIBCPP_ABI_FORCE_ITANIUM / _MICROSOFT off */
#define _LIBCPP_ABI_FORCE_ITANIUM 0
#define _LIBCPP_ABI_FORCE_MICROSOFT 0
#define _LIBCPP_HAS_THREADS 1
#define _LIBCPP_HAS_MONOTONIC_CLOCK 1
#define _LIBCPP_HAS_TERMINAL 1
#define _LIBCPP_HAS_MUSL_LIBC 0
#define _LIBCPP_HAS_THREAD_API_PTHREAD 1
#define _LIBCPP_HAS_THREAD_API_EXTERNAL 0
#define _LIBCPP_HAS_THREAD_API_WIN32 0
#define _LIBCPP_HAS_THREAD_API_C11 0
/* _LIBCPP_DISABLE_VISIBILITY_ANNOTATIONS off */
#define _LIBCPP_HAS_VENDOR_AVAILABILITY_ANNOTATIONS 0
/* _LIBCPP_NO_VCRUNTIME off */
/* _LIBCPP_TYPEINFO_COMPARISON_IMPLEMENTATION: leave to <typeinfo> default */
#define _LIBCPP_HAS_FILESYSTEM 1
#define _LIBCPP_HAS_RANDOM_DEVICE 1
#define _LIBCPP_HAS_LOCALIZATION 1
#define _LIBCPP_HAS_UNICODE 1
#define _LIBCPP_HAS_WIDE_CHARACTERS 1
/* _LIBCPP_HAS_NO_STD_MODULES off */
#define _LIBCPP_HAS_TIME_ZONE_DATABASE 1
#define _LIBCPP_INSTRUMENTED_WITH_ASAN 0

// PSTL: serial backend (no libdispatch dependency for the freestanding build).
#define _LIBCPP_PSTL_BACKEND_SERIAL

// Hardening: none (fast) -- matches release libc++.
#define _LIBCPP_HARDENING_MODE_DEFAULT _LIBCPP_HARDENING_MODE_NONE

#endif // _LIBCPP___CONFIG_SITE
