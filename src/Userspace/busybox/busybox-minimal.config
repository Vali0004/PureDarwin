CONFIG_BUSYBOX=y
CONFIG_SHOW_USAGE=y
CONFIG_FEATURE_VERBOSE_USAGE=y
CONFIG_FEATURE_BUFFERS_USE_MALLOC=y
CONFIG_INSTALL_APPLET_DONT=y
CONFIG_PREFIX="./_install"
# CONFIG_STATIC is not set
# CONFIG_PIE is not set
# CONFIG_NOMMU is not set
# CONFIG_FEATURE_INSTALLER is not set
CONFIG_EXTRA_CFLAGS="-fno-stack-protector -Wno-ignored-optimization-argument -Wno-string-plus-int"
CONFIG_EXTRA_LDFLAGS=""
CONFIG_EXTRA_LDLIBS=""

CONFIG_CAT=y
CONFIG_CHMOD=y
CONFIG_CP=y
CONFIG_ECHO=y
CONFIG_FALSE=y
CONFIG_LN=y
CONFIG_LS=y
CONFIG_MKDIR=y
CONFIG_MV=y
CONFIG_PWD=y
CONFIG_REBOOT=y
CONFIG_RM=y
CONFIG_RMDIR=y
CONFIG_SHUTDOWN=y
CONFIG_SLEEP=y
CONFIG_TEST=y
CONFIG_TRUE=y
CONFIG_UNAME=y

# Text/file utilities (portable; no /proc or Linux-only syscalls)
CONFIG_BASENAME=y
CONFIG_DIRNAME=y
CONFIG_HEAD=y
CONFIG_TAIL=y
CONFIG_WC=y
CONFIG_CUT=y
CONFIG_TR=y
CONFIG_SORT=y
CONFIG_UNIQ=y
CONFIG_GREP=y
CONFIG_SED=y
CONFIG_FIND=y
CONFIG_XARGS=y
CONFIG_TOUCH=y
CONFIG_DATE=y
CONFIG_ENV=y
CONFIG_ID=y
CONFIG_PRINTF=y
CONFIG_SEQ=y
CONFIG_YES=y
CONFIG_WHICH=y
CONFIG_HOSTNAME=y
CONFIG_DU=y
CONFIG_DD=y
CONFIG_KILL=y
CONFIG_CLEAR=y

CONFIG_SH_IS_ASH=y
CONFIG_ASH=y
# Run built-in applets (uname, ls, cat, ...) directly as commands, so a single
# busybox binary works as the whole userland with no /bin/<applet> symlinks.
CONFIG_FEATURE_PREFER_APPLETS=y
CONFIG_FEATURE_SH_STANDALONE=y
# Standalone ash re-execs this path to run a regular applet. The default
# /proc/self/exe does not exist on Darwin; point it at the staged busybox.
CONFIG_BUSYBOX_EXEC_PATH="/bin/busybox"
CONFIG_ASH_ECHO=y
CONFIG_ASH_PRINTF=y
CONFIG_ASH_TEST=y
CONFIG_ASH_GETOPTS=y
