+typedef struct {
+    uint32_t state[5];
+    uint64_t count;
+    unsigned char buffer[64];
+} X_SHA1_CTX;
+
+static uint32_t
+sha1_rol(uint32_t value, unsigned int bits)
+{
+    return (value << bits) | (value >> (32 - bits));
+}
+
+static uint32_t
+sha1_load_be32(const unsigned char *p)
+{
+    return ((uint32_t) p[0] << 24) |
+           ((uint32_t) p[1] << 16) |
+           ((uint32_t) p[2] << 8) |
+           (uint32_t) p[3];
+}
+
+static void
+sha1_store_be32(unsigned char *p, uint32_t v)
+{
+    p[0] = (unsigned char) (v >> 24);
+    p[1] = (unsigned char) (v >> 16);
+    p[2] = (unsigned char) (v >> 8);
+    p[3] = (unsigned char) v;
+}
+
+static void
+sha1_transform(X_SHA1_CTX *ctx, const unsigned char block[64])
+{
+    uint32_t w[80];
+    uint32_t a, b, c, d, e;
+    unsigned int i;
+
+    for (i = 0; i < 16; i++)
+        w[i] = sha1_load_be32(block + (i * 4));
+    for (i = 16; i < 80; i++)
+        w[i] = sha1_rol(w[i - 3] ^ w[i - 8] ^ w[i - 14] ^ w[i - 16], 1);
+
+    a = ctx->state[0];
+    b = ctx->state[1];
+    c = ctx->state[2];
+    d = ctx->state[3];
+    e = ctx->state[4];
+
+    for (i = 0; i < 80; i++) {
+        uint32_t f, k, temp;
+
+        if (i < 20) {
+            f = (b & c) | ((~b) & d);
+            k = 0x5a827999;
+        } else if (i < 40) {
+            f = b ^ c ^ d;
+            k = 0x6ed9eba1;
+        } else if (i < 60) {
+            f = (b & c) | (b & d) | (c & d);
+            k = 0x8f1bbcdc;
+        } else {
+            f = b ^ c ^ d;
+            k = 0xca62c1d6;
+        }
+
+        temp = sha1_rol(a, 5) + f + e + k + w[i];
+        e = d;
+        d = c;
+        c = sha1_rol(b, 30);
+        b = a;
+        a = temp;
+    }
+
+    ctx->state[0] += a;
+    ctx->state[1] += b;
+    ctx->state[2] += c;
+    ctx->state[3] += d;
+    ctx->state[4] += e;
+}
+
+static void
+sha1_init(X_SHA1_CTX *ctx)
+{
+    ctx->state[0] = 0x67452301;
+    ctx->state[1] = 0xefcdab89;
+    ctx->state[2] = 0x98badcfe;
+    ctx->state[3] = 0x10325476;
+    ctx->state[4] = 0xc3d2e1f0;
+    ctx->count = 0;
+}
+
+static void
+sha1_update(X_SHA1_CTX *ctx, const void *data, size_t len)
+{
+    const unsigned char *bytes = data;
+    size_t used = (size_t) (ctx->count & 63);
+
+    ctx->count += len;
+
+    if (used) {
+        size_t free_bytes = 64 - used;
+        if (len < free_bytes) {
+            memcpy(ctx->buffer + used, bytes, len);
+            return;
+        }
+        memcpy(ctx->buffer + used, bytes, free_bytes);
+        sha1_transform(ctx, ctx->buffer);
+        bytes += free_bytes;
+        len -= free_bytes;
+    }
+
+    while (len >= 64) {
+        sha1_transform(ctx, bytes);
+        bytes += 64;
+        len -= 64;
+    }
+
+    if (len)
+        memcpy(ctx->buffer, bytes, len);
+}
+
+static void
+sha1_final(unsigned char result[20], X_SHA1_CTX *ctx)
+{
+    uint64_t bit_count = ctx->count * 8;
+    unsigned char length[8];
+    unsigned char pad[64] = { 0x80 };
+    size_t used = (size_t) (ctx->count & 63);
+    size_t pad_len = (used < 56) ? (56 - used) : (120 - used);
+    unsigned int i;
+
+    for (i = 0; i < 8; i++)
+        length[7 - i] = (unsigned char) (bit_count >> (i * 8));
+
+    sha1_update(ctx, pad, pad_len);
+    sha1_update(ctx, length, sizeof(length));
+
+    for (i = 0; i < 5; i++)
+        sha1_store_be32(result + (i * 4), ctx->state[i]);
+}
 
